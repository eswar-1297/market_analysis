# ============================================================================
#  CloudFuze Marketing Dashboard — environment config
#  Copy this file to ".env" and fill in the values. NEVER commit .env.
#  Any blank source falls back to realistic SAMPLE data.
# ============================================================================

# --- Server ---
PORT=4000

# --- Dashboard login ---
DASHBOARD_USER=CFMARKETING
DASHBOARD_PASS=change-me

# --- Google Analytics 4 ---
# Numeric property ID (GA4 report URL: a<account>p<PROPERTY_ID>).
GA4_PROPERTY_ID=

# --- Google Search Console ---
# Exact property string, e.g. https://www.cloudfuze.com/  or  sc-domain:cloudfuze.com
SEARCH_CONSOLE_SITE_URL=

# --- Service-account credentials (GA4 + Search Console) ---
# DEPLOYMENT-FRIENDLY: base64 of the whole service-account JSON key, one line.
#   Generate:  base64 -w0 key.json     (or: certutil -encode / PowerShell)
GOOGLE_CREDENTIALS_B64=
# Alternative for local dev: absolute path to the JSON key file instead.
# GOOGLE_APPLICATION_CREDENTIALS=

# --- PageSpeed Insights / CrUX (real Core Web Vitals) ---
PAGESPEED_API_KEY=
